# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/marketplace_experiences

# Server Configuration
PORT=8080
HOST=127.0.0.1

# Environment
RUST_LOG=debug
RUST_BACKTRACE=1

# JWT Configuration (for future authentication)
JWT_SECRET=your-super-secret-jwt-key-here

# Resend Email Configuration (Recomendado - Más fácil de configurar)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Alternativa: SMTP Email Configuration (si prefieres SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_NAME=Marketplace Local
# SMTP_FROM_EMAIL=noreply@marketplace.com

# External Services (for future integrations)
# PAYMENT_GATEWAY_URL=
# EMAIL_SERVICE_URL=
# IMAGE_STORAGE_URL=